# Backend API (no trailing slash). Must be prefixed with VITE_ for Vite to expose to the client.
# Leave unset in local dev to use the Vite proxy (see vite.config.js) and avoid CORS.
# VITE_API_BASE_URL=http://localhost:8000

# Where Vite proxies /auth, /devices, /tickets, /health during npm run dev (default: http://localhost:8000).
# VITE_DEV_PROXY_TARGET=http://localhost:8000
#
# Windows: if uvicorn fails with WinError 10013 on port 8000, something else is using that port
# (or it is in an excluded range). Stop the other process, or run the API on another port and match:
#   python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8010
#   VITE_DEV_PROXY_TARGET=http://127.0.0.1:8010
