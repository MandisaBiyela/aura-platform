# PostgreSQL connection string.
#
# Docker (recommended): from project root run
#   docker compose up -d
# then use the URL below (default user/password/db match docker-compose.yml).
#
# If port 5432 is already in use, change the left port in docker-compose.yml
# (e.g. "5433:5432") and set DATABASE_URL host port to 5433.
#
# Example: postgresql://USER:PASSWORD@localhost:5432/aura_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aura_db

# JWT signing (use a long random string in production, e.g. openssl rand -hex 32)
SECRET_KEY=change-me-to-a-strong-secret
ALGORITHM=HS256

# Phase 2 — ticket NLP classifier (aura-ticket-ai on port 8001)
AI_SERVICE_URL=http://localhost:8001
# Legacy alias (optional): AI_CLASSIFIER_URL=http://localhost:8001
